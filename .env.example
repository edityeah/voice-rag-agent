# --- Voice agent providers ---
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4o-mini
CARTESIA_API_KEY=your_cartesia_api_key
CARTESIA_DEFAULT_VOICE_ID=2b27d5e4-bcf9-496c-a54b-2ab64b0986b2
DEEPGRAM_API_KEY=your_deepgram_api_key

# --- LiveKit ---
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret

# --- Web app ---
PUBLIC_URL=http://localhost:8000
SESSION_SECRET=generate_a_long_random_string
JWT_SECRET=generate_another_long_random_string
DATABASE_URL=sqlite:///./voice_agent.db

# --- Google OAuth (Console -> Credentials -> OAuth 2.0 client) ---
# Authorized redirect URI: http://localhost:8000/auth/callback
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

# --- Quota tuning (defaults: 15 min / 30 days) ---
QUOTA_SECONDS=900
QUOTA_PERIOD_DAYS=30
